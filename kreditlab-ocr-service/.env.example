# =============================================================================
# Tensorlake Document AI — Environment Variables
# =============================================================================
# Copy this file to `.env` and fill in only the keys for the providers you plan
# to use. Every section is independently optional; missing keys disable just
# the features that depend on them.
#
#   cp .env.example .env
#   set -a; source .env; set +a
#
# Then deploy:
#   tl deploy src/workflow.py
# =============================================================================

# ----- Tensorlake runtime (required) -----------------------------------------
# Get from https://tensorlake.ai → API Keys
TENSORLAKE_API_KEY=

# Min number of warm containers per @function (0 = scale-to-zero, cheaper but
# adds cold-start latency). Override per environment.
TENSORLAKE_MIN_CONTAINERS=0


# ----- OCR provider: Azure Document Intelligence (azure-di) ------------------
AZURE_DOCUMENT_INTELLIGENCE_ENDPOINT=
AZURE_DOCUMENT_INTELLIGENCE_KEY=


# ----- OCR provider: AWS Textract (textract) ---------------------------------
# Textract uploads async jobs to an S3 bucket — set it here. Same creds work
# for S3 file_url inputs of the form s3://<bucket>/<key>.
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_REGION=us-east-1
# Required ONLY for Textract async pipeline. Also required if your
# `file_url` uses the bare `s3://<key>` form (no bucket in the URL).
S3_BUCKET_NAME=


# ----- OCR provider: Gemini VLM (gemini) -------------------------------------
GEMINI_API_KEY=


# ----- OCR provider: DotsOCR on a CUDA GPU (dots-ocr) ------------------------
# No extra keys. Needs a CUDA-equipped host — either a `--local` run on your
# own GPU, or a managed Tensorlake GPU deployment (GPU workers aren't part
# of the open serverless tier today — contact support@tensorlake.ai if you'd
# like one provisioned). Weights are pulled from Hugging Face Hub on first
# cold-start.


# ----- VLM / LLM enrichment (table & figure summarization, structured
# extraction). Each provider key is independently optional. ------------------
OPENAI_API_KEY=
ANTHROPIC_API_KEY=
# GEMINI_API_KEY already set above is reused for VLM/LLM calls.
# QWEN_API_KEY is only needed if you select the Qwen provider in extraction.
QWEN_API_KEY=


# ----- Optional Azure OpenAI for cross-page header correction ----------------
# Set USE_AZURE_OPENAI=true to route header correction through Azure instead
# of the public OpenAI API.
USE_AZURE_OPENAI=false
AZURE_OPENAI_ENDPOINT=
AZURE_OPENAI_API_KEY=
AZURE_OPENAI_MODEL_DEPLOYMENT_NAME=


# ----- Resource overrides (optional, dots-ocr only) --------------------------
# Memory ceiling for the DotsOCR GPU container. Default 32 GB.
OCR_GPU_MEMORY_IN_GB=32

# Memory ceiling for the Ovis2.5 figure-OCR GPU container. Default 24 GB.
OVIS_MEMORY_IN_GB=24

# The `dots-ocr` pipeline (DotsOCR + Ovis2.5 figure OCR) declares
# `gpu=["H100", "A100-80GB"]` on its @function decorators, so the code is
# ready for those pools as soon as you have GPU access (see the dots-ocr
# section above for how to get it). To target a different GPU type, edit
# the `GPU_MODELS` constant at the top of `src/tensorlake_docai/ocr/dots_ocr.py`
# and `src/tensorlake_docai/ocr/figure_ocr.py`.
